# MySQL thường chạy ở Port 3306. 
# Tuy nhiên, biến PORT trong file .env ở backend là Port dành cho cái Server Node.js 
# của chúng ta chứ không phải của MySQL. Nếu bạn đặt Server Node.js chạy vào 
# cổng 3306 thì nó sẽ bị "đụng độ" với MySQL và báo lỗi không chạy được. 
PORT=5000 
DB_HOST=localhost
DB_USER=root
# Bạn hãy thay đổi DB_PASSWORD bằng mật khẩu MySQL thực tế của bạn
DB_PASSWORD=son123456
DB_NAME=macbook_store
# Secret key cho phần tạo Token, bạn có thể đổi thành chuỗi ngẫu nhiên bất kỳ
JWT_SECRET=super_secret_jwt_key_of_apple_store
